#  Flask Backend
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wildfire_db
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
SECRET_KEY=change-me-random-32-chars

#  PostgreSQL Container (must match DB_* above)
POSTGRES_DB=wildfire_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# ── Auth (GitHub OAuth) ───────────────────────────────────────────────────────
# Register an OAuth App at https://github.com/settings/developers
#   Homepage URL:        https://wildfire-ai.com
#   Authorization callback URL: https://wildfire-ai.com/api/auth/github/callback
# After login, the user is redirected to FRONTEND_URL with the JWT in the URL fragment.
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret
ADMIN_GITHUB_LOGIN=geo-raypan
FRONTEND_URL=https://wildfire-ai.com


# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to "claude" (default) or "gemini"
LLM_PROVIDER=claude
# CLAUDE_MODEL=claude-sonnet-4-6      # optional, this is the default
# GEMINI_MODEL=gemini-2.0-flash       # optional, this is the default

# Anthropic API — get yours at https://platform.claude.com/docs/en/api/admin/api_keys/retrieve
# WARNING: This key is tied to a paid account. Every API call incurs a cost.
#   - Do NOT commit your real key to any public or shared repository.
#   - Do NOT share this key with others.
#   - Set a monthly spend limit at https://console.anthropic.com/settings/limits
#     to prevent unexpected charges if the key is leaked or abused.
ANTHROPIC_API_KEY=your_anthropic_api_key

# Gemini API — get yours at https://aistudio.google.com/api-keys
# WARNING: If upgraded to a paid tier, leaking this key can incur charges.
#   - Do NOT commit your real key to any public or shared repository.
#   - Set API restrictions at https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=your_gemini_api_key

# ── Basemap ───────────────────────────────────────────────────────────────────
# Sentinel Hub — optional, enables date-aware Sentinel-2 satellite basemap
# Get credentials: https://apps.sentinel-hub.com/dashboard → User Settings → OAuth clients
# Credentials stay on the backend; tiles are proxied via /api/satellite/tile/
SENTINELHUB_CLIENT_ID=your_client_id
SENTINELHUB_CLIENT_SECRET=your_client_secret

# ── Data Sources ──────────────────────────────────────────────────────────────
# FIRMS Map Key — get yours at https://firms.modaps.eosdis.nasa.gov/api/map_key/
# Limit: 5000 transactions / 10 minutes (larger requests count as multiple)
FIRMS_API_KEY=your_firms_api_key

# Copernicus CDS Personal Access Token — get yours at https://cds.climate.copernicus.eu/profile
# Required for ERA5-Land weather data download
CDS_KEY=your_cds_key

# NASA Earthdata Bearer Token — get yours at https://urs.earthdata.nasa.gov/profile
# Required for VIIRS cloud mask download (optional — cloud masking disabled if not set)
EARTHDATA_TOKEN=your_earthdata_token
